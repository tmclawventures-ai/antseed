# Node identity — 64-char hex Ed25519 private key seed.
# When set, overrides all other identity storage (file, custom IdentityStore).
# Cleared from process environment immediately after read.
# Recommended for servers: inject from a secrets manager.
# ANTSEED_IDENTITY_HEX=

# Enable verbose runtime logs across packages (0/1)
ANTSEED_DEBUG=0

# Dashboard frontend debug logs (0/1)
VITE_ANTSEED_DEBUG=0

# Optional: override env file path for runtime env loading
# ANTSEED_ENV_FILE=.env

# Buyer peer discovery runtime override (milliseconds). Durable default lives in config.json.
# ANTSEED_BUYER_METADATA_FETCH_TIMEOUT_MS=750

# Settlement runtime (requires config.payments.crypto in config.json)
# Recommended for production sellers: use a dedicated Base JSON-RPC endpoint.
# ANTSEED_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/...
# ANTSEED_ENABLE_SETTLEMENT=true
# ANTSEED_SETTLEMENT_IDLE_MS=30000
# ANTSEED_DEFAULT_ESCROW_USDC=1
# ANTSEED_AUTO_FUND_ESCROW=true
# ANTSEED_SELLER_WALLET_ADDRESS=0x...
